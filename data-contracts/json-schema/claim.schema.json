{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim",
  "type": "object",
  "required": [
    "claim_id",
    "patient_id",
    "hospital_id",
    "scheme_id",
    "diagnosis",
    "procedure",
    "claim_amount",
    "admission_date",
    "document_text",
    "status",
    "risk_score",
    "risk_band",
    "fraud_flags",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "claim_id": { "type": "string" },
    "patient_id": { "type": "string" },
    "hospital_id": { "type": "string" },
    "scheme_id": { "type": "string", "enum": ["AB-ArK", "Yeshasvini"] },
    "diagnosis": { "type": "string" },
    "procedure": { "type": "string" },
    "claim_amount": { "type": "number", "minimum": 0 },
    "admission_date": { "type": "string" },
    "discharge_date": { "type": ["string", "null"] },
    "document_text": { "type": "string" },
    "supporting_documents": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" },
    "status": { "type": "string", "enum": ["submitted", "approved", "rejected", "review"] },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_band": { "type": "string", "enum": ["low", "medium", "high"] },
    "fraud_flags": { "type": "array", "items": { "type": "string" } },
    "patient_name": { "type": ["string", "null"] },
    "hospital_name": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}