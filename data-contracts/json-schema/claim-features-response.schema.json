{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimFeatureResponse",
  "type": "object",
  "required": ["claim_id", "patient_id", "hospital_id", "feature_labels", "feature_vector", "feature_summary", "claim_velocity", "overlap_flag", "spatiotemporal_flags", "generated_at"],
  "properties": {
    "claim_id": { "type": "string" },
    "patient_id": { "type": "string" },
    "hospital_id": { "type": "string" },
    "feature_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feature_vector": {
      "type": "array",
      "items": { "type": "number" }
    },
    "feature_summary": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "claim_velocity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "overlap_flag": { "type": "boolean" },
    "spatiotemporal_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_at": { "type": "string" }
  },
  "additionalProperties": false
}